# Copy to .env, fill the per-CEO values, then `source .env` before create_agent.py / run_loop.py.
# (.env is gitignored — never commit secrets.) The `new-ceo` setup skill fills the __PLACEHOLDERS__.

# --- per-CEO config ---
export GCP_PROJECT="__GCP_PROJECT__"                        # this CEO's dedicated GCP project id
export AGENT_ID="ai-ceo"                                    # agent id (one per project; fine to keep)
export WORKSPACE_REPO_URL="__REPO_URL__"                    # this CEO's git-memory repo (https://...git)
export WORKSPACE_TARGET="/workspace/repo"
export SECRET_MANAGER_PROJECT="$GCP_PROJECT"

# --- auth (proxy-only; hard isolation via a scoped SA) ---
# LOCAL runs: an account that owns the project, impersonating the scoped runner SA so the sandbox
# token reaches ONLY this project (any other project returns 403). On Cloud Run, leave these empty.
export GCLOUD_ACCOUNT="__OWNER_ACCOUNT__"
export IMPERSONATE_SA="ai-ceo-runner@${GCP_PROJECT}.iam.gserviceaccount.com"

# --- required ---
export GEMINI_API_KEY="$(gcloud secrets versions access latest --secret=gemini-api-key --project=$GCP_PROJECT --account=$GCLOUD_ACCOUNT 2>/dev/null)"
export GITHUB_PAT="$(gh auth token 2>/dev/null)"           # local: reuse your gh login for the private clone
export GITHUB_PAT_SECRET="github-pat"                      # SM secret with a push PAT (Cloud Run path)

# --- shared skills library (mounted as a second repo each loop) ---
export SKILLS_REPO_URL="https://github.com/SaschaHeyer/ceo-skills"
export SKILLS_TARGET="/workspace/ceo-skills"

# --- agent runtime ---
export BASE_AGENT="antigravity-preview-05-2026"
export LOOP_STREAM="1"

# --- per-loop cost tracking (the runner reads usage.* off each interaction) ---
export COST_LOG="runner/cost_log.yaml"    # append every loop's token usage as a YAML record (for charts)
export GEMINI_INPUT_RATE="1.50"           # $/1M input tokens (antigravity = gemini-3.5-flash)
export GEMINI_OUTPUT_RATE="9.00"          # $/1M output+thinking tokens
export GEMINI_CACHED_FACTOR="0.1"         # cached input billed at ~0.1x input ($0.15/1M)
